#!/usr/bin/env bash
# setwallpaper <path>
# Sets wallpaper, generates pywal colors, and updates SDDM background.

set -e

if [[ -z "$1" ]]; then
    echo "Usage: setwallpaper <path>"
    exit 1
fi

WALLPAPER="$(realpath "$1")"

if [[ ! -f "$WALLPAPER" ]]; then
    echo "File not found: $WALLPAPER"
    exit 1
fi

# Set desktop wallpaper
awww img "$WALLPAPER"

# Generate pywal colors (skip sequences and tty — apply after bg is patched)
wal -i "$WALLPAPER" -n -s -t

# Patch colors.json: desaturate background so pywal's teal bias doesn't bleed everywhere
python3 - <<'EOF'
import colorsys, json
from pathlib import Path

def desaturate(hex_color):
    h = hex_color.lstrip("#")
    r, g, b = (int(h[i:i+2], 16) / 255 for i in (0, 2, 4))
    hue, l, s = colorsys.rgb_to_hls(r, g, b)
    r2, g2, b2 = colorsys.hls_to_rgb(hue, l, 0)
    return "#{:02x}{:02x}{:02x}".format(int(r2*255), int(g2*255), int(b2*255))

p = Path.home() / ".cache/wal/colors.json"
data = json.loads(p.read_text())
neutral = desaturate(data["special"]["background"])
data["special"]["background"] = neutral
data["colors"]["color0"] = neutral
p.write_text(json.dumps(data, indent=4))
print(f"bg patched -> {neutral}")
EOF

# Re-export all pywal templates with patched colors and apply sequences
wal -R -n -t

# Apply GTK colors (pywal16 doesn't support postrun hooks)
python3 ~/.config/wal/postrun

# Push new colors to all running terminal instances
for pty in /dev/pts/[0-9]*; do
    cat ~/.cache/wal/sequences > "$pty" 2>/dev/null || true
done

# Reapply papirus folder color (needs sudo, runs here where a terminal is available)
sudo papirus-folders -C grey --theme Papirus-Dark

# Sync to SDDM silent theme backgrounds
sudo cp "$WALLPAPER" /usr/share/sddm/themes/silent/backgrounds/wallpaper.jpg

echo "Wallpaper set: $WALLPAPER"
